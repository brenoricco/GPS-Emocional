// =============================================================================
// GPS Emocional — schema v2 (pivô 2026-07)
//
// MVP linear: quiz → módulo → encerramento. Nada mais.
// Sem check-in, sem diário, sem escalas, sem IA, sem Stripe.
//
// Persistência opcional: só se a usuária escolher criar conta pra guardar
// histórico de constância ("Você cuidou de si por N dias"). Fluxo anônimo
// também funciona (constância em localStorage).
//
// Convenções:
//   - Modelos em PascalCase PT-BR
//   - Tabelas em snake_case PT-BR (via @@map)
//   - IDs em cuid()
//   - Sem String[]. Sem operadores JSON no banco.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

/// Os 5 módulos da jornada. Slug espelha o path em app/modulo/[slug].
enum ModuloTipo {
  LEVEZA_E_PAZ
  CURA_DO_CORACAO
  ROMPENDO_CICLOS
  RESGATANDO_CORES
  RESGATE_DO_VALOR
}

// =============================================================================
// USUÁRIA (opcional — só se criar conta)
// =============================================================================

model Usuaria {
  id                            String    @id @default(cuid())
  email                         String    @unique
  nomeExibicao                  String?
  termosAceitos                 Boolean   @default(false)
  termosAceitosEm               DateTime?
  consentimentoDadosSensiveis   Boolean   @default(false)
  consentimentoDadosSensiveisEm DateTime?
  dataExclusaoSolicitada        DateTime?
  criadoEm                      DateTime  @default(now())
  atualizadoEm                  DateTime  @updatedAt

  sessoesModulo SessaoModulo[]
  constancia    Constancia?

  @@map("usuarias")
}

// =============================================================================
// JORNADA
// =============================================================================

/// Cada vez que uma usuária conclui um módulo (fez o exercício, ouviu o áudio
/// e clicou em "Concluir Dia"), grava um SessaoModulo.
model SessaoModulo {
  id          String     @id @default(cuid())
  usuariaId  String
  modulo      ModuloTipo
  iniciadaEm  DateTime   @default(now())
  concluidaEm DateTime?

  usuaria Usuaria @relation(fields: [usuariaId], references: [id], onDelete: Cascade)

  @@index([usuariaId, iniciadaEm])
  @@map("sessoes_modulo")
}

/// Contador simples de constância — "Você cuidou de si por N dias seguidos".
/// Um por usuária. Atualizado ao concluir um módulo.
model Constancia {
  id                    String   @id @default(cuid())
  usuariaId             String   @unique
  diasConsecutivos      Int      @default(0)
  ultimoDiaConcluido    DateTime?
  totalSessoesConcluidas Int     @default(0)
  atualizadaEm          DateTime @updatedAt

  usuaria Usuaria @relation(fields: [usuariaId], references: [id], onDelete: Cascade)

  @@map("constancias")
}
