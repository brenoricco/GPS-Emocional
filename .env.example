# =============================================================================
# GPS Emocional — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env real. Segredos vão pro Railway via dashboard.
# =============================================================================

# --- Aplicação ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Banco de dados ---
# Dev local (SQLite): file:./dev.db
# Produção (Postgres Railway): postgresql://usuario:senha@host:porta/banco
DATABASE_URL="file:./dev.db"

# --- Autenticação (Auth.js v5) ---
# Gere com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (Resend) ---
# Para envio de magic link e notificações
RESEND_API_KEY=""
EMAIL_REMETENTE="GPS Emocional <ola@gpsemocional.com.br>"

# --- IA (Groq Cloud) ---
# Crie conta em console.groq.com e gere a API key
GROQ_API_KEY=""
# Modelos: meta-llama/llama-4-scout-17b-16e-instruct, qwen/qwen3-32b
IA_MODELO_PADRAO="meta-llama/llama-4-scout-17b-16e-instruct"
IA_MODELO_ANALISE="qwen/qwen3-32b"

# --- IA (Fallback opcional — Together.ai) ---
TOGETHER_API_KEY=""

# --- Pagamento (Stripe) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Criptografia de dados sensíveis (LGPD Art. 11) ---
# Usada pra cifrar campos como conteúdo de diário no banco
# Gere com: openssl rand -base64 32
CHAVE_CRIPTOGRAFIA_CONTEUDO=""
